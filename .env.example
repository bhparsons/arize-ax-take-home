# Copy to .env and fill in. Do NOT commit .env.

# --- Model provider auth ---
# Primary path: OpenRouter gateway — ONE key reaches Claude + GPT + Gemini through
# one OpenAI-compatible endpoint. Powers the core build, the model-swap bonus, and
# the LLM-judge. Get it at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...
# Optional native fallbacks (only if you bypass the gateway for a provider):
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...

# --- Web search tool (optional) ---
# Powers the agent's web_search tool. SEPARATE from OpenRouter — its own provider.
# Without it, web_search returns an honest "unavailable" and the agent falls back
# to docs. Get a free key (1k searches/mo) at https://tavily.com
# TAVILY_API_KEY=tvly-...

# --- Arize AX (preferred backend) ---
ARIZE_SPACE_ID=
ARIZE_API_KEY=
# Optional: only if the datasets/experiments SDK needs a separate developer key
# (the ingest ARIZE_API_KEY worked for both tracing AND experiments in testing).
# ARIZE_DEVELOPER_KEY=

# --- Phoenix Cloud (fallback backend; leave blank if using AX) ---
# PHOENIX_API_KEY=
# PHOENIX_COLLECTOR_ENDPOINT=https://app.phoenix.arize.com

# --- Which backend to use: "ax" or "phoenix" ---
TRACING_BACKEND=ax
PROJECT_NAME=dev-research-assistant
